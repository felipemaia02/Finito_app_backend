# Finito App Backend - Configurações de Ambiente

# Básico
APP_NAME=Finito App Backend
APP_VERSION=0.1.0
DEBUG=false

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=finito_app

# API
API_V1_STR=/api/v1

# Authentication - API Key
API_KEY=your-secret-api-key-change-in-env

# Authentication - JWT
SECRET_KEY=your-jwt-secret-key-change-in-env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=1
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7